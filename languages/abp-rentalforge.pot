#: includes/abprf_layout.php:660
msgid ""
"Note: There are three(3) types of deposit options: Fixed Amount (a set "
"deposit regardless of quantity), Percentage of Total Price (calculated based "
"on the total rental cost), and Fixed Amount per Quantity (applied for each "
"item rented)."
msgstr ""

